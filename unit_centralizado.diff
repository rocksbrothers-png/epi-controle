+// ---------------------------------------------------------------------------
+// Unit selection — centralizado (#144 C1+D1+E3)
+// ---------------------------------------------------------------------------
+// Regra acordada:
+// - general_admin / registry_admin: podem trocar livremente a Unidade,
+//   inclusive "Todas as Unidades" nos pontos que aceitam escopo GLOBAL.
+// - admin (Administrador Local) / user (Gestor de EPI): mantêm o lock na
+//   `operational_unit_id` do seu vínculo e não trocam Unidade.
+// - master_admin: sem lock (comportamento igual ao general_admin).
+// A lógica vive em `resolveUnitContext` para que todas as telas
+// (Cadastro de EPI, Controle de Estoque, Entrega de EPI, Relatórios) usem
+// a mesma fonte de verdade.
+
+function resolveUnitContext(options = {}) {
+  const { companyId: forcedCompanyId } = options;
+  const role = state.user?.role || '';
+  const locked = ['admin', 'user'].includes(role);
+  const operationalUnitId = locked
+    ? String(state.user?.operational_unit_id || '').trim()
+    : '';
+  const companyId = forcedCompanyId
+    || (locked ? String(state.user?.company_id || '') : '')
+    || '';
+  const companyScoped = filterByUserCompany(state.units);
+  let units = companyId
+    ? companyScoped.filter((item) => String(item.company_id) === String(companyId))
+    : companyScoped.slice();
+  if (locked) {
+    units = operationalUnitId
+      ? units.filter((item) => String(item.id) === operationalUnitId)
+      : [];
+  }
+  return {
+    role,
+    locked,
+    operationalUnitId,
+    units,
+    hasOperationalUnit: locked ? Boolean(operationalUnitId) : false
+  };
+}
+
+// Popula um <select> de unidade respeitando o contexto do usuário e
+// preservando a seleção anterior quando possível. Usada por Cadastro de EPI,
+// Controle de Estoque e Entrega de EPI para garantir uma única regra.
+function renderUnitSelect(selectEl, ctx, options = {}) {
+  if (!selectEl) return '';
+  const {
+    allOptionValue = '',
+    allOptionLabel = 'Todas as Unidades',
+    allowAllOption = false,
+    emptyLabel = 'Sem unidade operacional ativa'
+  } = options;
+  const previous = String(selectEl.value || '');
+  const { locked, operationalUnitId, units } = ctx;
+
+  if (locked && !units.length) {
+    selectEl.innerHTML = `<option value="">${emptyLabel}</option>`;
+    selectEl.value = '';
+    selectEl.disabled = true;
+    return '';
+  }
+
+  const unitOptions = units.map(formatUnitOption).join('');
+  const allOption = (!locked && allowAllOption)
+    ? `<option value="${allOptionValue}">${allOptionLabel}</option>`
+    : '';
+  selectEl.innerHTML = `${allOption}${unitOptions}`;
+
+  let nextValue = '';
+  if (locked) {
+    nextValue = String(operationalUnitId || (units[0] && units[0].id) || '');
+  } else if (allowAllOption && previous === allOptionValue) {
+    nextValue = allOptionValue;
+  } else if (previous && units.some((item) => String(item.id) === previous)) {
+    nextValue = previous;
+  } else if (allowAllOption) {
+    nextValue = allOptionValue;
+  } else if (units.length) {
+    nextValue = String(units[0].id);
+  }
+  selectEl.value = nextValue;
+  selectEl.disabled = locked;
+  return nextValue;
+}
